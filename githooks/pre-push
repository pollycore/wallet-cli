#!/bin/sh

set -eu

repo_root=$(git rev-parse --show-toplevel)
cd "$repo_root"

if [ ! -d ".venv" ]; then
  printf '%s\n' "pre-push: missing .venv. Create it and install dev dependencies first." >&2
  printf '%s\n' "pre-push: python3 -m venv .venv && . .venv/bin/activate && python -m pip install -e '.[dev]'" >&2
  exit 1
fi

if [ ! -x ".venv/bin/python" ]; then
  printf '%s\n' "pre-push: missing .venv/bin/python. Recreate the virtualenv before pushing." >&2
  exit 1
fi

printf '%s\n' "pre-push: running test suite..."
.venv/bin/python -m pytest
printf '%s\n' "pre-push: tests passed."

smoke_venv=".git/.pre-push-smoke-venv"
trap 'rm -rf "$smoke_venv"' EXIT HUP INT TERM

printf '%s\n' "pre-push: running clean-install smoke test..."
python3 -m venv "$smoke_venv"
"$smoke_venv/bin/python" -m pip install --upgrade pip >/dev/null
"$smoke_venv/bin/python" -m pip install '.[dev]' >/dev/null
"$smoke_venv/bin/python" -m pytest -q tests/test_cli_core.py -k 'dependency_contract'
printf '%s\n' "pre-push: clean-install smoke test passed."
